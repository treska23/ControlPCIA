<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ControlPCIA.Mobile.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#07111F">

    <ContentPage.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#0E1C2E" />
            <Setter Property="Stroke" Value="#203853" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeShape" Value="RoundRectangle 22" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#2563EB" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="MinimumHeightRequest" Value="54" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#172A42" />
            <Setter Property="TextColor" Value="#D9E8FA" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="MinimumHeightRequest" Value="48" />
        </Style>
        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#081421" />
            <Setter Property="Stroke" Value="#2D4968" />
            <Setter Property="StrokeShape" Value="RoundRectangle 14" />
            <Setter Property="Padding" Value="12,4" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="TextColor" Value="#E8F2FF" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout
            Padding="18,28,18,36"
            Spacing="16">

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="13">
                <Border
                    WidthRequest="54"
                    HeightRequest="54"
                    Padding="0"
                    BackgroundColor="#2563EB"
                    Stroke="#60A5FA"
                    StrokeShape="RoundRectangle 17">
                    <Label
                        Text="IA"
                        FontAttributes="Bold"
                        FontSize="20"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                    <Label Text="ControlPCIA" FontSize="24" FontAttributes="Bold" />
                    <Label
                        Text="Díselo al móvil. La IA local propone cómo hacerlo."
                        TextColor="#9CB4CE"
                        FontSize="13" />
                </VerticalStackLayout>
            </Grid>

            <Border x:Name="ConnectedBar" Style="{StaticResource Card}" IsVisible="False" Padding="14">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <VerticalStackLayout Spacing="2">
                        <Label
                            x:Name="PcConnectionLabel"
                            Text="PC conectado"
                            TextColor="#86EFAC"
                            FontAttributes="Bold" />
                        <Label
                            x:Name="ConnectedAddressLabel"
                            TextColor="#9CB4CE"
                            FontSize="12"
                            LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                    <Button
                        x:Name="ForgetButton"
                        Grid.Column="1"
                        Text="Cambiar"
                        Style="{StaticResource SecondaryButton}"
                        Clicked="OnForgetClicked" />
                </Grid>
            </Border>

            <Border x:Name="ConnectionPanel" Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Conecta tu PC" FontSize="21" FontAttributes="Bold" />
                        <Label
                            Text="El móvil y el PC deben estar en la misma Wi‑Fi. Pulsa buscar y la aplicación intentará encontrarlo sola."
                            TextColor="#AFC2D8"
                            LineHeight="1.2" />
                    </VerticalStackLayout>

                    <Button
                        x:Name="SearchButton"
                        Text="Buscar mi PC"
                        Style="{StaticResource PrimaryButton}"
                        Clicked="OnSearchClicked" />

                    <ActivityIndicator
                        x:Name="ConnectionActivity"
                        IsVisible="False"
                        IsRunning="False"
                        Color="#60A5FA" />

                    <Picker
                        x:Name="PcPicker"
                        Title="Elige un PC encontrado"
                        TextColor="#E8F2FF"
                        TitleColor="#9CB4CE"
                        BackgroundColor="#081421"
                        IsVisible="False"
                        ItemDisplayBinding="{Binding Descripcion}"
                        SelectedIndexChanged="OnPcSelected" />

                    <VerticalStackLayout Spacing="7">
                        <Label Text="Dirección del PC" FontAttributes="Bold" FontSize="13" />
                        <Border Style="{StaticResource FieldBorder}">
                            <Entry
                                x:Name="AddressEntry"
                                Placeholder="http://192.168.1.15:5187"
                                PlaceholderColor="#68819D"
                                TextColor="#E8F2FF"
                                Keyboard="Url" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="7">
                        <Label Text="Código de 6 cifras que aparece en el PC" FontAttributes="Bold" FontSize="13" />
                        <Border Style="{StaticResource FieldBorder}">
                            <Entry
                                x:Name="CodeEntry"
                                MaxLength="6"
                                Keyboard="Numeric"
                                HorizontalTextAlignment="Center"
                                FontSize="22"
                                CharacterSpacing="7"
                                Placeholder="000000"
                                PlaceholderColor="#68819D"
                                TextColor="#E8F2FF" />
                        </Border>
                    </VerticalStackLayout>

                    <Button
                        x:Name="ConnectButton"
                        Text="Conectar"
                        Style="{StaticResource PrimaryButton}"
                        Clicked="OnConnectClicked" />

                    <Label
                        x:Name="ConnectionStatusLabel"
                        TextColor="#9CB4CE"
                        LineHeight="1.2" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ControlPanel" Style="{StaticResource Card}" IsVisible="False">
                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="3">
                        <Label Text="Habla al PC" FontSize="22" FontAttributes="Bold" />
                        <Label
                            Text="El mismo micrófono sirve para encender el ordenador o darle cualquier orden."
                            TextColor="#AFC2D8"
                            LineHeight="1.2" />
                    </VerticalStackLayout>

                    <Border
                        x:Name="VoiceStateBorder"
                        BackgroundColor="#081421"
                        Stroke="#2D4968"
                        StrokeShape="RoundRectangle 18"
                        Padding="15">
                        <VerticalStackLayout Spacing="13">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <ActivityIndicator
                                    x:Name="VoiceActivity"
                                    WidthRequest="32"
                                    HeightRequest="32"
                                    Color="#60A5FA"
                                    IsVisible="False"
                                    IsRunning="False" />
                                <Border
                                    x:Name="VoiceIdleIndicator"
                                    WidthRequest="18"
                                    HeightRequest="18"
                                    Padding="0"
                                    BackgroundColor="#60A5FA"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 9"
                                    VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="1">
                                    <Label
                                        x:Name="VoiceStateTitle"
                                        Text="Preparado para escucharte"
                                        FontAttributes="Bold"
                                        FontSize="16" />
                                    <Label
                                        x:Name="VoiceDurationLabel"
                                        Text="00:00"
                                        TextColor="#86EFAC"
                                        FontSize="13"
                                        IsVisible="False" />
                                </VerticalStackLayout>
                            </Grid>

                            <Grid
                                ColumnDefinitions="*,78"
                                ColumnSpacing="14"
                                MinimumHeightRequest="188">
                                <VerticalStackLayout
                                    Spacing="10"
                                    VerticalOptions="Center">
                                    <Label
                                        x:Name="VoiceTranscriptLabel"
                                        Text="Mantén pulsado el micrófono, habla y suelta para enviar."
                                        TextColor="#9CB4CE"
                                        LineHeight="1.2" />
                                    <Label
                                        x:Name="VoiceActionLabel"
                                        Text="Mantén pulsado para hablar"
                                        TextColor="#86EFAC"
                                        FontAttributes="Bold"
                                        FontSize="13" />
                                    <Button
                                        x:Name="CancelVoiceButton"
                                        Text="Cancelar grabación"
                                        Style="{StaticResource SecondaryButton}"
                                        HorizontalOptions="Start"
                                        IsVisible="False"
                                        Clicked="OnCancelVoiceClicked" />
                                    <Label
                                        x:Name="VoiceModeHelpLabel"
                                        Text="Mientras hablas, desliza el círculo hacia el candado para fijarlo."
                                        TextColor="#7890AA"
                                        FontSize="12" />
                                </VerticalStackLayout>

                                <Grid
                                    Grid.Column="1"
                                    HeightRequest="176"
                                    WidthRequest="72"
                                    HorizontalOptions="Center">
                                    <Border
                                        x:Name="VoiceLockRail"
                                        WidthRequest="52"
                                        HeightRequest="176"
                                        Padding="7"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        BackgroundColor="#172A42"
                                        Stroke="#3D5875"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 26"
                                        IsVisible="True"
                                        Opacity="0.65">
                                        <Grid RowDefinitions="Auto,*,Auto">
                                            <Image
                                                x:Name="VoiceLockIcon"
                                                Grid.Row="0"
                                                Source="lock.svg"
                                                WidthRequest="22"
                                                HeightRequest="22"
                                                HorizontalOptions="Center" />
                                            <Label
                                                x:Name="VoiceLockHintLabel"
                                                Grid.Row="1"
                                                Text="↑"
                                                TextColor="#FFFFFF"
                                                FontAttributes="Bold"
                                                FontSize="22"
                                                HorizontalTextAlignment="Center"
                                                VerticalTextAlignment="Center" />
                                            <BoxView
                                                Grid.Row="2"
                                                WidthRequest="8"
                                                HeightRequest="8"
                                                CornerRadius="4"
                                                HorizontalOptions="Center"
                                                Color="#5EE58A" />
                                        </Grid>
                                    </Border>

                                    <Border
                                        x:Name="VoiceGestureSurface"
                                        WidthRequest="64"
                                        HeightRequest="64"
                                        Padding="17"
                                        HorizontalOptions="Center"
                                        VerticalOptions="End"
                                        BackgroundColor="#16A34A"
                                        Stroke="#5EE58A"
                                        StrokeThickness="2"
                                        StrokeShape="RoundRectangle 32"
                                        AutomationProperties.IsInAccessibleTree="True"
                                        SemanticProperties.Description="Micrófono"
                                        SemanticProperties.Hint="Mantén pulsado para hablar, suelta para enviar o desliza hacia arriba hasta el candado">
                                        <Grid>
                                            <Image
                                                x:Name="VoiceMicIcon"
                                                Source="microphone.svg"
                                                Aspect="AspectFit" />
                                            <Image
                                                x:Name="VoiceSendIcon"
                                                Source="send.svg"
                                                Aspect="AspectFit"
                                                IsVisible="False" />
                                            <Image
                                                x:Name="VoiceButtonLockBadge"
                                                Source="lock.svg"
                                                WidthRequest="13"
                                                HeightRequest="13"
                                                HorizontalOptions="End"
                                                VerticalOptions="Start"
                                                TranslationX="10"
                                                TranslationY="-10"
                                                IsVisible="False" />
                                            <ActivityIndicator
                                                x:Name="VoiceButtonActivity"
                                                Color="#FFFFFF"
                                                IsVisible="False"
                                                IsRunning="False" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <VerticalStackLayout Spacing="7">
                        <Label Text="También puedes escribir" FontAttributes="Bold" FontSize="13" />
                        <Border Style="{StaticResource FieldBorder}" Padding="12">
                            <Editor
                                x:Name="OrderEditor"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="105"
                                MaxLength="1000"
                                Placeholder="Por ejemplo: abre YouTube y busca un vídeo"
                                PlaceholderColor="#68819D"
                                TextColor="#E8F2FF" />
                        </Border>
                        <Button
                            x:Name="SendButton"
                            Text="Enviar mensaje escrito"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnSendClicked" />
                    </VerticalStackLayout>

                    <Border BackgroundColor="#081421" Stroke="#203853" StrokeShape="RoundRectangle 14" Padding="13">
                        <Label
                            x:Name="ControlStatusLabel"
                            Text="Preparado para recibir una orden."
                            TextColor="#AFC2D8" />
                    </Border>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Conversación con la IA" FontAttributes="Bold" />
                        <VerticalStackLayout x:Name="HistoryStack" Spacing="7">
                            <Label
                                x:Name="EmptyHistoryLabel"
                                Text="Aquí aparecerán tus mensajes y las respuestas de la IA. El contexto sólo se conserva durante esta sesión."
                                TextColor="#7890AA"
                                FontSize="13" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <Button
                        x:Name="RemoteToggleButton"
                        Text="Abrir ratón y teclado"
                        Style="{StaticResource SecondaryButton}"
                        Clicked="OnRemoteToggleClicked" />

                    <Border
                        x:Name="RemoteControlPanel"
                        BackgroundColor="#081421"
                        Stroke="#2D4968"
                        StrokeShape="RoundRectangle 18"
                        Padding="14"
                        IsVisible="False">
                        <VerticalStackLayout Spacing="13">
                            <VerticalStackLayout Spacing="3">
                                <Label
                                    Text="Control remoto"
                                    FontSize="20"
                                    FontAttributes="Bold" />
                                <Label
                                    Text="Mueve el dedo por el panel. Un toque hace clic izquierdo."
                                    TextColor="#9CB4CE"
                                    FontSize="13" />
                            </VerticalStackLayout>

                            <Border
                                x:Name="RemoteTouchpad"
                                HeightRequest="220"
                                BackgroundColor="#10233A"
                                Stroke="#3D5875"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18"
                                AutomationProperties.IsInAccessibleTree="True"
                                SemanticProperties.Description="Panel táctil remoto"
                                SemanticProperties.Hint="Desliza para mover el puntero o toca para hacer clic izquierdo">
                                <Grid>
                                    <Label
                                        Text="DESLIZA PARA MOVER"
                                        TextColor="#58738F"
                                        FontSize="12"
                                        CharacterSpacing="2"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center" />
                                    <Border
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        Padding="0"
                                        BackgroundColor="#173557"
                                        Stroke="#4A6C91"
                                        StrokeShape="RoundRectangle 22"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        Opacity="0.65">
                                        <Label
                                            Text="⌁"
                                            TextColor="#AFC2D8"
                                            FontSize="25"
                                            HorizontalTextAlignment="Center"
                                            VerticalTextAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>

                            <Grid
                                ColumnDefinitions="*,*,*,*"
                                ColumnSpacing="7">
                                <Button
                                    Grid.Column="0"
                                    Text="Clic"
                                    Style="{StaticResource SecondaryButton}"
                                    Clicked="OnRemoteMouseClicked"
                                    CommandParameter="left-click" />
                                <Button
                                    Grid.Column="1"
                                    Text="Derecho"
                                    Style="{StaticResource SecondaryButton}"
                                    Clicked="OnRemoteMouseClicked"
                                    CommandParameter="right-click" />
                                <Button
                                    Grid.Column="2"
                                    Text="Rueda ↑"
                                    Style="{StaticResource SecondaryButton}"
                                    Clicked="OnRemoteMouseClicked"
                                    CommandParameter="wheel-up" />
                                <Button
                                    Grid.Column="3"
                                    Text="Rueda ↓"
                                    Style="{StaticResource SecondaryButton}"
                                    Clicked="OnRemoteMouseClicked"
                                    CommandParameter="wheel-down" />
                            </Grid>

                            <Button
                                x:Name="RemoteDragButton"
                                Text="Mantener clic para arrastrar"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnRemoteDragClicked" />

                            <BoxView HeightRequest="1" Color="#203853" />

                            <VerticalStackLayout Spacing="7">
                                <Label
                                    Text="Teclado"
                                    FontAttributes="Bold"
                                    FontSize="15" />
                                <Border Style="{StaticResource FieldBorder}" Padding="10">
                                    <Editor
                                        x:Name="RemoteTextEditor"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="80"
                                        MaxLength="500"
                                        Placeholder="Escribe el texto que quieres enviar a la ventana activa"
                                        PlaceholderColor="#68819D"
                                        TextColor="#E8F2FF" />
                                </Border>
                                <Button
                                    Text="Escribir texto en el PC"
                                    Style="{StaticResource PrimaryButton}"
                                    Clicked="OnRemoteTextClicked" />
                            </VerticalStackLayout>

                            <Grid
                                RowDefinitions="Auto,Auto,Auto"
                                ColumnDefinitions="*,*,*,*"
                                RowSpacing="7"
                                ColumnSpacing="7">
                                <Button Grid.Row="0" Grid.Column="0" Text="Esc" Style="{StaticResource SecondaryButton}" CommandParameter="esc" Clicked="OnRemoteKeyClicked" />
                                <Button Grid.Row="0" Grid.Column="1" Text="Tab" Style="{StaticResource SecondaryButton}" CommandParameter="tab" Clicked="OnRemoteKeyClicked" />
                                <Button Grid.Row="0" Grid.Column="2" Text="Intro" Style="{StaticResource SecondaryButton}" CommandParameter="enter" Clicked="OnRemoteKeyClicked" />
                                <Button Grid.Row="0" Grid.Column="3" Text="⌫" Style="{StaticResource SecondaryButton}" CommandParameter="backspace" Clicked="OnRemoteKeyClicked" />
                                <Button Grid.Row="1" Grid.Column="0" Text="←" Style="{StaticResource SecondaryButton}" CommandParameter="left" Clicked="OnRemoteKeyClicked" />
                                <Button Grid.Row="1" Grid.Column="1" Text="↑" Style="{StaticResource SecondaryButton}" CommandParameter="up" Clicked="OnRemoteKeyClicked" />
                                <Button Grid.Row="1" Grid.Column="2" Text="↓" Style="{StaticResource SecondaryButton}" CommandParameter="down" Clicked="OnRemoteKeyClicked" />
                                <Button Grid.Row="1" Grid.Column="3" Text="→" Style="{StaticResource SecondaryButton}" CommandParameter="right" Clicked="OnRemoteKeyClicked" />
                                <Button Grid.Row="2" Grid.Column="0" Text="Ctrl+C" Style="{StaticResource SecondaryButton}" CommandParameter="ctrl+c" Clicked="OnRemoteKeyClicked" />
                                <Button Grid.Row="2" Grid.Column="1" Text="Ctrl+V" Style="{StaticResource SecondaryButton}" CommandParameter="ctrl+v" Clicked="OnRemoteKeyClicked" />
                                <Button Grid.Row="2" Grid.Column="2" Text="Ctrl+A" Style="{StaticResource SecondaryButton}" CommandParameter="ctrl+a" Clicked="OnRemoteKeyClicked" />
                                <Button Grid.Row="2" Grid.Column="3" Text="Ctrl+Z" Style="{StaticResource SecondaryButton}" CommandParameter="ctrl+z" Clicked="OnRemoteKeyClicked" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Border Style="{StaticResource FieldBorder}">
                                    <Entry
                                        x:Name="RemoteShortcutEntry"
                                        Placeholder="Atajo: Ctrl+Shift+S"
                                        PlaceholderColor="#68819D"
                                        TextColor="#E8F2FF"
                                        MaxLength="40" />
                                </Border>
                                <Button
                                    Grid.Column="1"
                                    Text="Enviar"
                                    Style="{StaticResource SecondaryButton}"
                                    Clicked="OnRemoteShortcutClicked" />
                            </Grid>

                            <Label
                                x:Name="RemoteStatusLabel"
                                Text="La entrada se enviará a la ventana que esté activa en el PC."
                                TextColor="#7890AA"
                                FontSize="12" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Label
                Text="Puede crear, abrir, guardar, copiar e instalar. Nunca puede borrar o cortar archivos ni realizar operaciones destructivas sobre discos."
                TextColor="#68819D"
                FontSize="11"
                HorizontalTextAlignment="Center"
                Margin="8,2" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
